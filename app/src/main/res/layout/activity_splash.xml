<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#854F0B"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvSplashIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏠"
        android:textSize="80sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KosKita"
        android:textColor="#FFFFFF"
        android:textSize="42sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"/>

    <TextView
        android:id="@+id/tvSplashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kelola kos, lebih mudah"
        android:textColor="#FAC775"
        android:textSize="15sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="60dp"/>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#FAC775"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textColor="#BA7517"
        android:textSize="11sp"
        android:layout_marginTop="16dp"/>

</LinearLayout>