<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#854F0B"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="#33FFFFFF"
                android:gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelola Request"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Tab Filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#703F08"
            android:orientation="horizontal"
            android:padding="3dp">

            <TextView
                android:id="@+id/tabSemua"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="#FFFFFF"
                android:gravity="center"
                android:padding="8dp"
                android:text="Semua"
                android:textColor="#854F0B"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tabMenunggu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="Menunggu"
                android:textColor="#FAC775"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tabDiproses"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="Diproses"
                android:textColor="#FAC775"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tabSelesai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="8dp"
                android:text="Selesai"
                android:textColor="#FAC775"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Tekan lama item untuk update status"
        android:textColor="#888780"
        android:textSize="11sp"
        android:fontFamily="sans-serif-italic"/>

    <TextView
        android:id="@+id/tvEmptyRequest"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="🔧&#10;&#10;Belum ada request&#10;Request perbaikan dari penghuni akan muncul di sini"
        android:textColor="@color/kk_text_hint"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvKelolaRequest"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"/>

</LinearLayout>