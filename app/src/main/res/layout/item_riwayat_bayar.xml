<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_menu_card"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Row atas: bulan + status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBulanRiwayat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mei 2026"
                android:textColor="#2C2C2A"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTanggalBayar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dibayar: 2 Mei 2026"
                android:textColor="#888780"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatusRiwayat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#EAF3DE"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Lunas"
            android:textColor="#3B6D11"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#F5C4B3"
        android:layout_marginBottom="8dp"/>

    <!-- Row bawah: nominal + metode -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nominal"
                android:textColor="#888780"
                android:textSize="10sp"/>

            <TextView
                android:id="@+id/tvNominalRiwayat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 650.000"
                android:textColor="#854F0B"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEmojiMetode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏦"
                android:textSize="16sp"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/tvMetodeBayar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transfer Bank"
                android:textColor="#5F5E5A"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>