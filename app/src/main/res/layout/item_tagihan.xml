<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_menu_card"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Row atas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#2C2C2A"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvKamarTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888780"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatusTagihan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#F5C4B3"
        android:layout_marginBottom="8dp"/>

    <!-- Row bawah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBulanTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888780"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvNominalTagihan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#854F0B"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnKonfirmasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#EAF3DE"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="✓ Konfirmasi"
            android:textColor="#3B6D11"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>