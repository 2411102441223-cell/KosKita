<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_menu_card"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Row atas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvNomorKamar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@color/kk_primary_mid"
            android:gravity="center"
            android:text="1A"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLantaiKamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lantai 1"
                android:textColor="@color/kk_text_hint"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvHargaKamar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 650.000/bln"
                android:textColor="@color/kk_primary"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatusKamar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Kosong"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/kk_border"
        android:layout_marginBottom="8dp"/>

    <!-- Row bawah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNamaPenghuni"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kamar kosong"
            android:textColor="@color/kk_text_secondary"
            android:textSize="12sp"
            android:drawablePadding="4dp"/>

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/kk_primary_surface"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="✏️ Edit"
            android:textColor="@color/kk_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btnHapus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FCEBEB"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="🗑 Hapus"
            android:textColor="#A32D2D"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>