<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_menu_card"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Row atas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/kk_primary_mid"
            android:gravity="center"
            android:text="👤"
            android:textSize="20sp"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaPenghuniItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kk_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvEmailPenghuniItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kk_text_hint"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/tvKamarPenghuniItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/kk_primary"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/kk_border"
        android:layout_marginBottom="8dp"/>

    <!-- Tombol Hapus -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHapusPenghuni"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="🗑 Hapus Akun Penghuni Ini"
        android:textSize="12sp"
        android:textStyle="bold"
        app:backgroundTint="#FCEBEB"
        app:cornerRadius="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:textColor="#A32D2D"/>

</LinearLayout>