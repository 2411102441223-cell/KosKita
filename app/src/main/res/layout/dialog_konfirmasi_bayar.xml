<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Konfirmasi Pembayaran"
        android:textColor="#2C2C2A"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvInfoTagihan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kamar 1A - Mei 2026\nNominal: Rp 650.000"
        android:textColor="#5F5E5A"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Metode Pembayaran"
        android:textColor="#2C2C2A"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgMetode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbTransfer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏦 Transfer Bank"
            android:textSize="13sp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/rbQris"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱 QRIS"
            android:textSize="13sp"/>

        <RadioButton
            android:id="@+id/rbTunai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💵 Tunai"
            android:textSize="13sp"/>
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKonfirmasiDialog"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Konfirmasi Lunas"
        android:textStyle="bold"
        app:backgroundTint="#854F0B"
        app:cornerRadius="10dp"/>

</LinearLayout>