<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kk_bg"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/kk_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="#33FFFFFF"
            android:gravity="center"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notifikasi"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnBacaSemua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#33FFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="✓ Baca"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/btnHapusSemua"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#33FFFFFF"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="🗑 Hapus"
            android:textColor="#FFFFFF"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Badge belum dibaca -->
    <TextView
        android:id="@+id/tvBelumDibaca"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/kk_primary_surface"
        android:padding="10dp"
        android:text="3 notifikasi belum dibaca"
        android:textColor="@color/kk_primary"
        android:textSize="12sp"
        android:gravity="center"
        android:textStyle="bold"
        android:visibility="gone"/>

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyNotif"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="🔔&#10;&#10;Belum ada notifikasi&#10;Notifikasi akan muncul di sini"
        android:textColor="@color/kk_text_hint"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:visibility="gone"/>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifikasi"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false"/>

</LinearLayout>